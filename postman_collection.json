{
  "info": {
    "name": "Craftsmen Marketplace API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Full API collection for the craftsmen marketplace backend.\n\nSet two collection variables before using:\n- baseUrl: http://localhost:5000 (or wherever the backend runs)\n- token: paste a JWT after signing in (Auth > Signin response)",
