    {
      "name": "Payments (Paymob)",
      "item": [
        { "name": "Start Checkout", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/payments/checkout", "body": { "mode": "raw", "raw": "{\n  \"orderId\": \"<ORDER_ID>\"\n}" }, "description": "Customer-side. Creates a pending Payment doc for the order and returns the Paymob hosted-checkout URL. The frontend redirects the browser to that URL." } },
        { "name": "Webhook (Paymob calls this)", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/payments/webhook?hmac=<PAYMOB_HMAC>", "body": { "mode": "raw", "raw": "{\n  \"obj\": { \"...\": \"Paymob transaction object\" }\n}" }, "description": "Server-to-server callback from Paymob. PUBLIC route — Paymob doesn't send our JWT — but the handler verifies the HMAC signature before trusting the body. Not for manual use." } },
        { "name": "Get Payment Status", "request": { "method": "GET", "url": "{{baseUrl}}/api/payments/:paymentId/status", "description": "Polled by the /checkout/result page if the redirect lands before the webhook." } }
      ]
    },
    {
      "name": "Worker Payouts (Paymob)",
      "item": [
        { "name": "Get Payout Info", "request": { "method": "GET", "url": "{{baseUrl}}/api/worker/payouts/info", "description": "Worker — read the saved payout destination so the form can prefill." } },
        { "name": "Set Payout Info", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/worker/payouts/info", "body": { "mode": "raw", "raw": "{\n  \"method\": \"instapay\",\n  \"instapayAlias\": \"name@instapay\",\n  \"bankAccountNumber\": \"\",\n  \"bankName\": \"\",\n  \"accountHolderName\": \"\",\n  \"walletPhone\": \"\"\n}" }, "description": "Worker — set/update where withdrawals are sent. `method` selects which of bank/instapay/wallet fields apply." } },
        { "name": "Request Withdrawal", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/worker/payouts/withdraw", "body": { "mode": "raw", "raw": "{\n  \"amount\": 100\n}" }, "description": "Worker — reserve the amount from wallet (atomically) and call Paymob Payouts. On Paymob error the reservation is refunded automatically." } },
        { "name": "List Withdrawals", "request": { "method": "GET", "url": "{{baseUrl}}/api/worker/payouts/withdrawals", "description": "Worker — only the withdrawal-source transactions (order-credits stay on /api/worker/wallet)." } },
        { "name": "Payout Webhook (Paymob calls this)", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/worker/payouts/webhook?hmac=<PAYMOB_HMAC>", "body": { "mode": "raw", "raw": "{\n  \"obj\": { \"...\": \"Paymob payout result\" }\n}" }, "description": "Paymob payout result callback. PUBLIC route, HMAC-verified inside the handler. Not for manual use." } }
      ]
    }
  ]
