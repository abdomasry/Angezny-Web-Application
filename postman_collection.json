      "name": "Support",
      "item": [
        { "name": "Create Ticket", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/support/tickets", "body": { "mode": "raw", "raw": "{\n  \"type\": \"service_issue\",\n  \"title\": \"Issue with order\",\n  \"message\": \"Worker did not show up\",\n  \"targetOrderId\": \"\",\n  \"attachments\": []\n}" } } },
        { "name": "List My Tickets", "request": { "method": "GET", "url": "{{baseUrl}}/api/support/tickets" } },
        { "name": "Get Ticket", "request": { "method": "GET", "url": "{{baseUrl}}/api/support/tickets/:id" } },
        { "name": "Add Reply", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/support/tickets/:id/reply", "body": { "mode": "raw", "raw": "{\n  \"message\": \"Any update?\"\n}" } } }
