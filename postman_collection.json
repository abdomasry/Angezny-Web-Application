    {
      "name": "Orders",
      "item": [
        { "name": "Create Order (customer)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/customer/orders", "body": { "mode": "raw", "raw": "{\n  \"serviceId\": \"SERVICE_ID\",\n  \"scheduledDate\": \"2026-05-10T10:00:00Z\",\n  \"address\": \"123 Main St, Cairo\",\n  \"lat\": 30.0444,\n  \"lng\": 31.2357,\n  \"governorate\": \"القاهرة\",\n  \"city\": \"Cairo\",\n  \"notes\": \"Optional notes\",\n  \"paymentMode\": \"cash_on_delivery\",\n  \"couponCode\": \"\",\n  \"problemImages\": []\n}" }, "description": "problemImages: optional array of up to 5 Cloudinary image URLs (customer-uploaded photos of the problem)." } },
        { "name": "Cancel Order (customer)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/customer/orders/:id/cancel", "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Plans changed\"\n}" } } },
        { "name": "Update Order Status (worker)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/worker/orders/:id/status", "body": { "mode": "raw", "raw": "{\n  \"status\": \"accepted\"\n}" } } },
        { "name": "Respond To Cancellation (worker)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/worker/orders/:id/cancellation", "body": { "mode": "raw", "raw": "{\n  \"action\": \"approved\",\n  \"denialReason\": \"\"\n}" } } },
        { "name": "Create Worker-Initiated Order (worker)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/worker/orders", "body": { "mode": "raw", "raw": "{\n  \"customerId\": \"CUSTOMER_USER_ID\",\n  \"customTitle\": \"Replace breaker\",\n  \"customPrice\": 600,\n  \"paymentTiming\": \"before\",\n  \"paymentMode\": \"card\",\n  \"location\": { \"address\": \"On-site\", \"lat\": 30.0444, \"lng\": 31.2357, \"governorate\": \"القاهرة\", \"city\": \"Cairo\" }\n}" } } },
        { "name": "Confirm Worker Order (customer)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/customer/orders/:id/confirm", "body": { "mode": "raw", "raw": "{}" } } },
        { "name": "Reject Worker Order (customer)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/customer/orders/:id/reject", "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Too expensive\"\n}" } } },
        { "name": "Get Customer Profile (worker)", "request": { "method": "GET", "url": "{{baseUrl}}/api/worker/customers/:id" } }
      ]
