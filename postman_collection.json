    {
      "name": "Chat",
      "description": "Customer<->Worker DMs over REST + Socket.IO.\n\nAI Assistant: GET /api/chat/conversations auto-creates a dedicated 'ai' conversation per user (pinned first; `type: \"ai\"`, otherUser.role = \"ai\"). Sending messages to it triggers the Groq pipeline over Socket.IO and emits ai:stream:start / ai:stream / ai:stream:end / ai:error events back to the user's room. No REST endpoints — the AI flow is entirely socket-driven. Requires GROQ_API_KEY in .env and the seeded AI user (run: node src/scripts/seed-ai-user.js).",
      "item": [
        { "name": "List Conversations (now includes pinned 'ai' row)", "request": { "method": "GET", "url": "{{baseUrl}}/api/chat/conversations" } },
        { "name": "Find Or Create Conversation", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/api/chat/conversations", "body": { "mode": "raw", "raw": "{\n  \"userId\": \"USER_ID\",\n  \"serviceId\": \"SERVICE_ID\"\n}" } } },
        { "name": "Get Conversation", "request": { "method": "GET", "url": "{{baseUrl}}/api/chat/conversations/:id" } },
